# Runner-Up Score Program

scores = []

n = int(input("How many scores do you want to enter? "))

for i in range(n):
    score = int(input(f"Enter score {i + 1}: "))
    scores.append(score)

unique_scores = list(set(scores))
unique_scores.sort()

print("Runner-up score:", unique_scores[-2])





