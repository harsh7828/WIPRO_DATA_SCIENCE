sample_list = [(10, 20, 40), (40, 50, 60), (70, 80, 90)]

print("Original List:")
print(sample_list)

new_list = []

for item in sample_list:
    new_tuple = item[:-1] + (100,)
    new_list.append(new_tuple)

print("Updated List:")
print(new_list)


Output

Original List:
[(10, 20, 40), (40, 50, 60), (70, 80, 90)]

Updated List:
[(10, 20, 100), (40, 50, 100), (70, 80, 100)]
