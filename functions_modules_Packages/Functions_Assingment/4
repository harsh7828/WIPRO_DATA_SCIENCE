def count_letters(text):
    upper = 0
    lower = 0

    for ch in text:
        if ch.isupper():
            upper += 1
        elif ch.islower():
            lower += 1

    print("Uppercase letters:", upper)
    print("Lowercase letters:", lower)

text = input("Enter a string: ")

count_letters(text)


output : Enter a string: Hello World
Uppercase letters: 2
Lowercase letters: 8
