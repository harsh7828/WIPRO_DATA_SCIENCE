# Assignment 4

numbers = [10, -5, 20, -8, 15, 30, -25, 40, -2, 50]

try:
    index = int(input("Enter index (0-9): "))

    if numbers[index] >= 0:
        print("Positive Number")
    else:
        print("Negative Number")

except IndexError:
    print("Error: Invalid index.")

except ValueError:
    print("Error: Please enter a valid integer.")
